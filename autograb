local pulseTween
local function pulseAnimation()
    if pulseTween then pulseTween:Cancel() end
    
    pulseTween = TweenService:Create(
        ProgressBar,
        TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut, -1, true),
        {BackgroundTransparency = 0.3}
    )
    pulseTween:Play()
end

local function updateProgress(progress, isActive)
    if _G.InstaPickup or isActive then
        ProgressContainer.Visible = true
        local width = math.clamp(progress, 0, 100)
        ProgressBar.Size = UDim2.new(width / 100, 0, 1, 0)
        ProgressText.Text = string.format("%d%%", math.floor(width))
        
        if isActive then
            if width < 30 then
                ProgressBar.BackgroundColor3 = Color3.fromRGB(255, 50, 100)
            elseif width < 70 then
                ProgressBar.BackgroundColor3 = Color3.fromRGB(200, 50, 255)
            else
                ProgressBar.BackgroundColor3 = Color3.fromRGB(180, 0, 255)
            end
            
            Gradient.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, ProgressBar.BackgroundColor3),
                ColorSequenceKeypoint.new(0.5, Color3.fromRGB(
                    math.min(255, ProgressBar.BackgroundColor3.R * 255 + 40),
                    math.min(255, ProgressBar.BackgroundColor3.G * 255 + 40),
                    math.min(255, ProgressBar.BackgroundColor3.B * 255 + 40)
                )),
                ColorSequenceKeypoint.new(1, ProgressBar.BackgroundColor3)
            })
            
            pulseAnimation()
        else
            ProgressBar.BackgroundColor3 = Color3.fromRGB(80, 0, 120)
            Gradient.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(80, 0, 120)),
                ColorSequenceKeypoint.new(0.5, Color3.fromRGB(100, 0, 150)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(80, 0, 120))
            })
            if pulseTween then
                pulseTween:Cancel()
                pulseTween = nil
            end
        end
    else
        ProgressContainer.Visible = false
        if pulseTween then
            pulseTween:Cancel()
            pulseTween = nil
        end
        ProgressBar.Size = UDim2.new(0, 0, 1, 0)
        ProgressText.Text = "0%"
    end
end

local function startGrabAnimation(duration)
    _G.IsGrabbing = true
    
    local startTime = tick()
    local endTime = startTime + duration
    
    while tick() < endTime and _G.IsGrabbing and _G.InstaPickup do
        local elapsed = tick() - startTime
        local progress = math.min((elapsed / duration) * 100, 100)
        
        updateProgress(progress, true)
        RunService.RenderStepped:Wait()
    end
    
    if _G.IsGrabbing and _G.InstaPickup then
        updateProgress(100, true)
        task.wait(0.3)
        updateProgress(0, false)
        _G.IsGrabbing = false
    else
        updateProgress(0, false)
        _G.IsGrabbing = false
    end
end

